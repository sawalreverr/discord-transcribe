# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_bot_client_id_here
TEST_GUILD_ID=your_test_server_id_here

# Transcription Provider Configuration
TRANSCRIPTION_PROVIDER=groq

# Groq API Configuration (required if TRANSCRIPTION_PROVIDER=groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=whisper-large-v3
GROQ_LANGUAGE=id

# Whisper.cpp Configuration (required if TRANSCRIPTION_PROVIDER=local)
WHISPER_CPP_PATH=./whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL_PATH=./whisper.cpp/models/ggml-large-v3-turbo.bin
WHISPER_LANGUAGE=id
WHISPER_THREADS=4
WHISPER_INITIAL_PROMPT=Berikut adalah transkrip percakapan dalam bahasa Indonesia.
WHISPER_SPLIT_ON_WORD=true
WHISPER_SUPPRESS_NST=true

# Whisper.cpp Server Mode (faster - avoids process spawn overhead)
# Enable this to use whisper-server instead of spawning whisper-cli per chunk
# Start server first: ./whisper.cpp/build/bin/whisper-server -m <model> -l id --port 8080
WHISPER_SERVER_MODE=false
WHISPER_SERVER_HOST=127.0.0.1
WHISPER_SERVER_PORT=8080

# Rate Limiting (within free tier)
RATE_LIMIT_RPM=6
RATE_LIMIT_RPD=14400

# Audio Processing
MAX_CHUNK_SECONDS=25
MAX_SILENCE_MS=1000
AUDIO_SAMPLE_RATE=16000

# Output Configuration
LOG_DIR=logs
LOG_LEVEL=info