{
    "name": "discord-transcribe",
    "version": "1.0.0",
    "description": "Real-time discord voice transcription bot using Groq API and local whisper.cpp",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "nodemon --exec tsx src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
        "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch"
    },
    "keywords": [
        "discord",
        "bot",
        "transcription",
        "whisper",
        "typescript"
    ],
    "license": "MIT",
    "engines": {
        "node": ">=22.12.0"
    },
    "dependencies": {
        "@discordjs/opus": "^0.10.0",
        "@discordjs/voice": "^0.19.0",
        "discord.js": "^14.18.0",
        "dotenv": "^16.4.7",
        "node-opus": "^0.3.3",
        "openai": "^4.90.0",
        "opusscript": "^0.1.1",
        "prism-media": "^1.3.5",
        "rate-limiter-flexible": "^6.2.1",
        "wav": "^1.0.2",
        "winston": "^3.17.0",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@jest/globals": "^29.7.0",
        "@types/node": "^22.14.0",
        "@types/wav": "^1.0.4",
        "@typescript-eslint/eslint-plugin": "^8.29.0",
        "@typescript-eslint/parser": "^8.29.0",
        "eslint": "^9.23.0",
        "eslint-config-prettier": "^10.1.1",
        "jest": "^29.7.0",
        "nodemon": "^3.1.9",
        "prettier": "^3.5.3",
        "tsx": "^4.19.0",
        "typescript": "^5.8.2"
    }
}
